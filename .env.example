# Вариант A: файл .env рядом с app.py (или football-stats/.env).
# Вариант B: если редактор не даёт сохранять .env — используйте livescore.local.env
#   в корне проекта или football-stats/livescore.local.env (те же имена переменных).

LIVESCORE_API_KEY=
LIVESCORE_API_SECRET=
# Необязательно: идентификатор турнира РПЛ в LiveScore API (по умолчанию 7).
# LIVESCORE_RPL_COMPETITION_ID=7
